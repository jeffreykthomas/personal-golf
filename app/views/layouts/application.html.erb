<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || app_shell_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#0B1929">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="<%= app_shell_title %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon-96x96.png" type="image/png" sizes="96x96">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-dark-bg" data-controller="coach-launcher">
    <!-- Single unified header -->
    <header class="app-header sticky top-0 z-30 bg-dark-bg/90 backdrop-blur-md border-b border-dark-border">
      <div class="px-4 h-14 flex items-center justify-between">
        <%= link_to app_home_path, class: 'flex items-center gap-2 no-underline' do %>
          <span class="text-white font-semibold text-lg tracking-tight"><%= app_shell_title %></span>
        <% end %>
        <% if user_signed_in? %>
          <div class="flex items-center gap-3">
            <%= button_to "Log out",
                session_path,
                method: :delete,
                class: "text-xs text-dark-text-muted hover:text-white transition-colors" %>
            <%= link_to header_shortcut_path, class: "relative p-1.5 rounded-full hover:bg-dark-surface transition-colors", title: header_shortcut_label do %>
              <%= nav_icon(life_mode? ? :self_report : :saved) %>
              <% if header_shortcut_badge_count > 0 %>
                <span class="absolute -top-0.5 -right-0.5 min-w-4 h-4 bg-accent-500 rounded-full text-[10px] text-white font-bold flex items-center justify-center px-1">
                  <%= header_shortcut_badge_count %>
                </span>
              <% end %>
            <% end %>
            <%= link_to settings_path, class: "w-8 h-8 bg-accent-500 rounded-full flex items-center justify-center", title: "Settings" do %>
              <span class="text-white font-medium text-sm"><%= current_user.display_name.first.upcase %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <% if user_signed_in? %>
      <%= turbo_stream_from "user_#{current_user.id}" %>
      <div id="notifications" class="fixed top-16 right-4 z-40 w-full max-w-sm space-y-2"></div>
    <% end %>

    <% coach_enabled = user_signed_in? && coach_feature_enabled? %>

    <% if user_signed_in? %>
      <div id="app-shell"
           <% if coach_enabled %>
             data-controller="coach-panel"
             data-coach-panel-sessions-url-value="<%= coach_sessions_path %>"
             data-coach-panel-voice-signed-url-value="<%= coach_voice_signed_url_path %>"
             data-coach-panel-voice-transcribe-url-value="<%= coach_voice_transcribe_path %>"
             data-coach-panel-voice-synthesize-url-value="<%= coach_voice_synthesize_path %>"
             data-coach-panel-context-value="<%= json_escape(coach_context_payload.to_json) %>"
             data-coach-panel-phase-value="<%= coach_phase_for_page %>"
             data-coach-panel-auto-open-value="<%= coach_auto_open? %>"
           <% end %>>

        <!-- Main page content -->
        <main data-coach-panel-target="mainContent" class="pb-[4.5rem]">
          <%= yield %>
        </main>

        <% if coach_enabled %>
          <!-- Full-screen coach chat (hidden until Coach tab is tapped) -->
          <section
            data-coach-panel-target="panel"
            class="hidden fixed top-14 bottom-[4.5rem] inset-x-0 z-40 bg-dark-bg flex flex-col items-center">

            <div class="w-full max-w-2xl flex flex-col flex-1 min-h-0">
              <div class="flex items-center justify-between px-4 py-3 border-b border-dark-border">
                <div>
                  <h2 class="text-white font-semibold text-lg">Coach</h2>
                  <p class="text-caption text-xs" data-coach-panel-target="phaseLabel"></p>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#toggleSpeaker" data-coach-panel-target="speakerButton" title="Toggle voice">
                    🔊
                  </button>
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#toggleMic" data-coach-panel-target="micButton" title="Toggle microphone">
                    🎤
                  </button>
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#close" title="Close coach">
                    ✕
                  </button>
                </div>
              </div>

              <div class="flex-1 overflow-y-auto px-4 pt-3 pb-2 flex flex-col gap-2" data-coach-panel-target="messages">
                <div class="flex-1 shrink-0"></div>
              </div>

              <div class="px-4 pb-4 pt-2 border-t border-dark-border">
                <p class="text-caption text-xs mb-2 hidden" data-coach-panel-target="status"></p>
                <form data-coach-panel-target="form" data-action="submit->coach-panel#sendMessage" class="flex items-end gap-2">
                  <textarea
                    class="flex-1 w-full bg-dark-surface border border-dark-border rounded-xl px-4 py-3 text-white placeholder-dark-text-muted focus-ring text-sm leading-5 resize-none overflow-y-auto min-h-[2.75rem] max-h-36"
                    placeholder="Ask your coach..."
                    data-coach-panel-target="input"
                    data-action="input->coach-panel#autoGrowInput keydown->coach-panel#handleInputKeydown"
                    maxlength="600"
                    rows="1"></textarea>
                  <button type="submit" class="btn-primary !py-3 !px-5 !rounded-xl text-sm">Send</button>
                </form>
              </div>
            </div>
          </section>
        <% end %>

        <!-- Bottom navigation -->
        <nav class="fixed bottom-0 left-0 right-0 z-50 bg-dark-surface/95 backdrop-blur-md border-t border-dark-border">
          <div class="grid grid-cols-5 items-end h-[4.5rem] max-w-lg mx-auto pb-safe">
            <% bottom_nav_items(coach_enabled: coach_enabled).each do |item| %>
              <% if item[:kind] == :coach %>
                <% if item[:enabled] %>
                  <button type="button"
                          class="bottom-nav-item coach-nav-button"
                          data-action="coach-panel#toggle"
                          data-coach-panel-target="navButton">
                    <div class="coach-nav-orb">
                      <%= nav_icon(item[:icon], classes: "w-6 h-6") %>
                    </div>
                    <span class="text-[10px] mt-1 font-medium"><%= item[:label] %></span>
                  </button>
                <% else %>
                  <div class="bottom-nav-item opacity-30">
                    <%= nav_icon(item[:icon]) %>
                    <span class="text-[10px] mt-0.5 font-medium"><%= item[:label] %></span>
                  </div>
                <% end %>
              <% else %>
                <%= link_to item[:path], class: "bottom-nav-item #{item[:active] ? 'bottom-nav-active' : ''}" do %>
                  <%= nav_icon(item[:icon]) %>
                  <span class="text-[10px] mt-0.5 font-medium"><%= item[:label] %></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </nav>
      </div>
    <% else %>
      <main>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
