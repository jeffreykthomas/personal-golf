<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Personal Golf" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-dark-bg" data-controller="coach-launcher">
    <!-- Single unified header -->
    <header class="app-header sticky top-0 z-30 bg-dark-bg/90 backdrop-blur-md border-b border-dark-border">
      <div class="px-4 h-14 flex items-center justify-between">
        <%= link_to tips_path, class: 'flex items-center gap-2 no-underline' do %>
          <span class="text-white font-semibold text-lg tracking-tight">Personal Golf</span>
        <% end %>
        <% if user_signed_in? %>
          <div class="flex items-center gap-3">
            <%= link_to saved_tips_path, class: "relative p-1.5 rounded-full hover:bg-dark-surface transition-colors" do %>
              <svg class="w-5 h-5 text-dark-text-muted" fill="currentColor" viewBox="0 0 20 20">
                <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v13.586l-6-6-6 6V4z"/>
              </svg>
              <% saved_count = current_user.saved_tip_items.count %>
              <% if saved_count > 0 %>
                <span class="absolute -top-0.5 -right-0.5 min-w-4 h-4 bg-accent-500 rounded-full text-[10px] text-white font-bold flex items-center justify-center px-1">
                  <%= saved_count %>
                </span>
              <% end %>
            <% end %>
            <div class="w-8 h-8 bg-accent-500 rounded-full flex items-center justify-center">
              <span class="text-white font-medium text-sm"><%= current_user.display_name.first.upcase %></span>
            </div>
          </div>
        <% end %>
      </div>
    </header>

    <% if user_signed_in? %>
      <%= turbo_stream_from "user_#{current_user.id}" %>
      <div id="notifications" class="fixed top-16 right-4 z-40 w-full max-w-sm space-y-2"></div>
    <% end %>

    <% coach_enabled = user_signed_in? && coach_feature_enabled? %>

    <% if user_signed_in? %>
      <div id="app-shell"
           <% if coach_enabled %>
             data-controller="coach-panel"
             data-coach-panel-sessions-url-value="<%= coach_sessions_path %>"
             data-coach-panel-voice-signed-url-value="<%= coach_voice_signed_url_path %>"
             data-coach-panel-voice-transcribe-url-value="<%= coach_voice_transcribe_path %>"
             data-coach-panel-voice-synthesize-url-value="<%= coach_voice_synthesize_path %>"
             data-coach-panel-context-value="<%= json_escape(coach_context_payload.to_json) %>"
             data-coach-panel-phase-value="<%= coach_phase_for_page %>"
             data-coach-panel-auto-open-value="<%= coach_auto_open? %>"
           <% end %>>

        <!-- Main page content -->
        <main data-coach-panel-target="mainContent" class="pb-[4.5rem]">
          <%= yield %>
        </main>

        <% if coach_enabled %>
          <!-- Full-screen coach chat (hidden until Coach tab is tapped) -->
          <section
            data-coach-panel-target="panel"
            class="hidden fixed top-14 bottom-[4.5rem] inset-x-0 z-40 bg-dark-bg flex flex-col items-center">

            <div class="w-full max-w-2xl flex flex-col flex-1 min-h-0">
              <div class="flex items-center justify-between px-4 py-3 border-b border-dark-border">
                <div>
                  <h2 class="text-white font-semibold text-lg">Coach</h2>
                  <p class="text-caption text-xs" data-coach-panel-target="phaseLabel"></p>
                </div>
                <div class="flex items-center gap-2">
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#toggleSpeaker" data-coach-panel-target="speakerButton" title="Toggle voice">
                    🔊
                  </button>
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#toggleMic" data-coach-panel-target="micButton" title="Toggle microphone">
                    🎤
                  </button>
                  <button type="button" class="coach-icon-btn" data-action="coach-panel#close" title="Close coach">
                    ✕
                  </button>
                </div>
              </div>

              <div class="flex-1 overflow-y-auto px-4 py-4 space-y-3" data-coach-panel-target="messages"></div>

              <div class="px-4 pb-4 pt-2 border-t border-dark-border">
                <p class="text-caption text-xs mb-2 hidden" data-coach-panel-target="status"></p>
                <form data-coach-panel-target="form" data-action="submit->coach-panel#sendMessage" class="flex gap-2">
                  <input
                    type="text"
                    class="flex-1 bg-dark-surface border border-dark-border rounded-xl px-4 py-3 text-white placeholder-dark-text-muted focus-ring text-sm"
                    placeholder="Ask your coach..."
                    data-coach-panel-target="input"
                    maxlength="600" />
                  <button type="submit" class="btn-primary !py-3 !px-5 !rounded-xl text-sm">Send</button>
                </form>
              </div>
            </div>
          </section>
        <% end %>

        <!-- Bottom navigation -->
        <nav class="fixed bottom-0 left-0 right-0 z-50 bg-dark-surface/95 backdrop-blur-md border-t border-dark-border">
          <div class="grid grid-cols-5 items-end h-[4.5rem] max-w-lg mx-auto pb-safe">
            <%= link_to tips_path, class: "bottom-nav-item #{controller_name == 'tips' && action_name == 'index' ? 'bottom-nav-active' : ''}" do %>
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"/>
              </svg>
              <span class="text-[10px] mt-0.5 font-medium">Home</span>
            <% end %>

            <%= link_to saved_tips_path, class: "bottom-nav-item #{controller_name == 'tips' && action_name == 'saved' ? 'bottom-nav-active' : ''}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
              <span class="text-[10px] mt-0.5 font-medium">Saved</span>
            <% end %>

            <% if coach_enabled %>
              <button type="button"
                      class="bottom-nav-item coach-nav-button"
                      data-action="coach-panel#toggle"
                      data-coach-panel-target="navButton">
                <div class="coach-nav-orb">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
                <span class="text-[10px] mt-1 font-medium">Coach</span>
              </button>
            <% else %>
              <div class="bottom-nav-item opacity-30">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <span class="text-[10px] mt-0.5 font-medium">Coach</span>
              </div>
            <% end %>

            <%= link_to courses_path, class: "bottom-nav-item #{controller_name == 'courses' ? 'bottom-nav-active' : ''}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21V3l6 3 6-3 6 3v18l-6-3-6 3-6-3z"/>
              </svg>
              <span class="text-[10px] mt-0.5 font-medium">Courses</span>
            <% end %>

            <%= link_to categories_path, class: "bottom-nav-item #{controller_name == 'categories' ? 'bottom-nav-active' : ''}" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
              <span class="text-[10px] mt-0.5 font-medium">Browse</span>
            <% end %>
          </div>
        </nav>
      </div>
    <% else %>
      <main>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
