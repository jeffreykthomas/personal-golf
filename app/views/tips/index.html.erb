<div class="px-6 py-8">
  <% if @next_tip %>
    <div id="tip-display" class="max-w-md mx-auto">
      <%= render partial: "tips/swipeable_tip_card", locals: { tip: @next_tip } %>
    </div>
  <% else %>
    <div class="max-w-md mx-auto text-center py-12">
      <%= render partial: "tips/no_more_tips" %>
    </div>
  <% end %>

  <!-- Quick stats -->
  <div class="max-w-md mx-auto mt-8 grid grid-cols-3 gap-4">
    <div class="bg-dark-card rounded-xl p-4 text-center border border-dark-border">
      <p class="text-2xl font-bold text-white"><%= @tips.count %></p>
      <p class="text-caption">Tips Saved</p>
    </div>

    <div class="bg-dark-card rounded-xl p-4 text-center border border-dark-border">
      <p class="text-2xl font-bold text-white"><%= current_user.handicap || "—" %></p>
      <p class="text-caption">Handicap</p>
    </div>

    <div class="bg-dark-card rounded-xl p-4 text-center border border-dark-border">
      <p class="text-2xl font-bold text-white"><%= current_user.tips_viewed_count %></p>
      <p class="text-caption">Tips Viewed</p>
    </div>
  </div>
</div>
