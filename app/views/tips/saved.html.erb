<div class="container mx-auto p-4 md:p-6 lg:p-8">
  <%= render 'tips/saved_tips_header' %>

  <main class="px-6 py-6">
    <% if @has_any_saved_tips %>
      <%= render "tips/saved_tip_list", saved_tips: @saved_tips %>
    <% else %>
      <div class="text-center py-12">
        <div class="golf-ball-orb w-24 h-24 mb-6 opacity-50">
          <div class="golf-ball-dimples"></div>
        </div>
        <h3 class="text-heading mb-2">No saved tips yet</h3>
        <p class="text-body mb-6">
          Start exploring tips and save the ones<br>
          that resonate with your game.
        </p>
        <%= link_to "Browse Tips", tips_path, class: "btn-primary inline-block" %>
      </div>
    <% end %>
  </main>
</div>
