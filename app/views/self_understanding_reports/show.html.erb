<div class="max-w-4xl mx-auto px-4 py-6 md:px-6">
  <div class="mb-6">
    <p class="text-xs uppercase tracking-[0.2em] text-accent-400 mb-2">Life Mode</p>
    <h1 class="text-3xl font-semibold text-white">Self-Understanding Report</h1>
    <p class="text-dark-text-muted mt-2 max-w-2xl">
      A living synthesis of what the agent has actually seen so far. It refreshes overnight when there is meaningful new signal to incorporate.
    </p>
  </div>

  <% if @report.present? %>
    <section class="rounded-3xl border border-dark-border bg-dark-surface/80 p-6 mb-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
        <div>
          <p class="text-xs uppercase tracking-[0.16em] text-dark-text-muted"><%= @report.framework_name %></p>
          <h2 class="text-2xl font-semibold text-white mt-1"><%= @report.title %></h2>
        </div>
        <div class="text-sm text-dark-text-muted">
          Updated <%= @report.generated_at.strftime("%b %-d, %Y at %-I:%M %p") %>
        </div>
      </div>
    </section>

    <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-3 mb-6">
      <% @report.ordered_currents.each do |current| %>
        <% score = current["score"] || current[:score] %>
        <% summary = current["summary"] || current[:summary] %>
        <% signals = Array(current["signals"] || current[:signals]).first(3) %>
        <% definition = NineCurrents.definition_for(current["name"] || current[:name]) %>
        <article class="rounded-2xl border border-dark-border bg-dark-surface/70 p-5">
          <div class="flex items-center justify-between gap-3 mb-3">
            <h3 class="text-white font-semibold"><%= current["name"] || current[:name] %></h3>
            <% if score.present? %>
              <span class="rounded-full bg-accent-500/10 px-2.5 py-1 text-xs font-medium text-accent-300"><%= score %>/10</span>
            <% end %>
          </div>
          <% if definition.present? %>
            <p class="mb-3 text-xs leading-5 text-accent-200/80"><%= definition.summary %></p>
          <% end %>
          <p class="text-sm leading-6 text-dark-text-muted"><%= summary %></p>
          <% if definition.present? %>
            <div class="mt-4 rounded-xl border border-dark-border bg-dark-bg/50 px-3 py-2 text-xs leading-5 text-dark-text-muted">
              <div><span class="font-medium text-dark-text">Inspiration:</span> <%= definition.enneagram_inspiration %></div>
              <div class="mt-1"><span class="font-medium text-dark-text">Question:</span> <%= definition.growth_question %></div>
            </div>
          <% end %>
          <% if signals.any? %>
            <div class="mt-4 space-y-2">
              <% signals.each do |signal| %>
                <div class="rounded-xl bg-dark-bg/70 px-3 py-2 text-xs leading-5 text-dark-text-muted">
                  <%= signal %>
                </div>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </section>

    <section class="rounded-3xl border border-dark-border bg-dark-surface/80 p-6">
      <div class="text-sm leading-7 text-dark-text-muted">
        <%= simple_format(@report.body_markdown) %>
      </div>
    </section>

    <% if @profile_inventory.present? %>
      <% counts = @profile_inventory["counts"] || {} %>
      <% categories = Array(@profile_inventory["categories"]) %>
      <section class="mt-6 rounded-3xl border border-dark-border bg-dark-surface/80 p-6">
        <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-xs uppercase tracking-[0.16em] text-dark-text-muted">Structured profile</p>
            <h2 class="text-2xl font-semibold text-white mt-1">Profile Field Inventory</h2>
            <p class="mt-2 max-w-2xl text-sm leading-6 text-dark-text-muted">
              The report references this underlying field map. Populated fields show what the agent currently believes it knows; unknown fields show where more evidence would sharpen the picture.
            </p>
          </div>
          <div class="flex flex-wrap gap-2 text-xs">
            <span class="rounded-full bg-accent-500/10 px-3 py-1.5 font-medium text-accent-300">
              <%= counts["populated_fields"] || 0 %> populated
            </span>
            <span class="rounded-full bg-dark-bg/80 px-3 py-1.5 font-medium text-dark-text-muted">
              <%= counts["unknown_fields"] || 0 %> unknown
            </span>
            <span class="rounded-full bg-dark-bg/80 px-3 py-1.5 font-medium text-dark-text-muted">
              <%= counts["total_fields"] || 0 %> total
            </span>
          </div>
        </div>

        <% if @profile_inventory["updated_at"].present? %>
          <p class="mt-3 text-xs text-dark-text-muted">
            Inventory updated <%= Time.zone.parse(@profile_inventory["updated_at"]).strftime("%b %-d, %Y at %-I:%M %p") rescue @profile_inventory["updated_at"] %>
          </p>
        <% end %>

        <div class="mt-6 space-y-3">
          <% categories.each do |category| %>
            <% category_counts = category["counts"] || {} %>
            <details class="group rounded-2xl border border-dark-border bg-dark-bg/50">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3">
                <div>
                  <h3 class="font-semibold text-white"><%= category["label"] || category["key"].to_s.humanize %></h3>
                  <% if category["description"].present? %>
                    <p class="mt-1 text-xs text-dark-text-muted"><%= category["description"] %></p>
                  <% end %>
                </div>
                <div class="flex shrink-0 items-center gap-2">
                  <span class="rounded-full bg-dark-surface px-2.5 py-1 text-xs text-dark-text-muted">
                    <%= category_counts["populated_fields"] || 0 %>/<%= category_counts["total_fields"] || 0 %>
                  </span>
                  <span class="text-dark-text-muted transition-transform group-open:rotate-90">›</span>
                </div>
              </summary>

              <div class="border-t border-dark-border divide-y divide-dark-border">
                <% Array(category["fields"]).each do |field| %>
                  <% value = field["value"] %>
                  <div class="px-4 py-3">
                    <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                      <div>
                        <div class="flex flex-wrap items-center gap-2">
                          <h4 class="text-sm font-medium text-white"><%= field["key"].to_s.humanize %></h4>
                          <code class="rounded bg-dark-surface px-1.5 py-0.5 text-[11px] text-dark-text-muted"><%= field["key"] %></code>
                          <span class="rounded bg-dark-surface px-1.5 py-0.5 text-[11px] text-dark-text-muted"><%= field["type"] %></span>
                        </div>
                        <% if field["prompt"].present? %>
                          <p class="mt-1 text-xs leading-5 text-dark-text-muted"><%= field["prompt"] %></p>
                        <% end %>
                      </div>
                      <span class="shrink-0 rounded-full px-2.5 py-1 text-xs font-medium <%= field["populated"] ? "bg-emerald-500/10 text-emerald-300" : "bg-dark-surface text-dark-text-muted" %>">
                        <%= field["populated"] ? "Populated" : "Unknown" %>
                      </span>
                    </div>

                    <% if field["populated"] %>
                      <div class="mt-3 rounded-xl bg-dark-surface/70 p-3 text-xs leading-5 text-dark-text-muted">
                        <% if value.is_a?(Array) || value.is_a?(Hash) %>
                          <pre class="whitespace-pre-wrap break-words"><%= JSON.pretty_generate(value) %></pre>
                        <% else %>
                          <%= value %>
                        <% end %>
                      </div>
                    <% elsif field["options"].present? %>
                      <p class="mt-2 text-xs text-dark-text-muted">
                        Options: <%= Array(field["options"]).join(", ") %>
                      </p>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </details>
          <% end %>
        </div>
      </section>
    <% end %>
  <% else %>
    <section class="rounded-3xl border border-dashed border-dark-border bg-dark-surface/50 p-8 text-center">
      <div class="max-w-xl mx-auto">
        <div class="inline-flex h-16 w-16 items-center justify-center rounded-full bg-accent-500/10 text-accent-300 mb-5">
          <%= nav_icon(:self_report, classes: "w-8 h-8") %>
        </div>
        <h2 class="text-2xl font-semibold text-white mb-3">Your report will appear here</h2>
        <p class="text-dark-text-muted leading-7 mb-6">
          Once there is enough meaningful context to synthesize, the agent will generate your first self-understanding report overnight and keep it current as new signal arrives.
        </p>
        <%= link_to "Open settings", settings_path, class: "btn-primary inline-flex items-center !rounded-xl !px-5 !py-3 text-sm" %>
      </div>
    </section>
  <% end %>
</div>
