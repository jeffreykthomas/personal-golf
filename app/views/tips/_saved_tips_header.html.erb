<div class="saved-tips-header bg-dark-card p-4 shadow-md rounded-lg mb-4 border border-dark-border" data-controller="form-submission">
  <div class="flex justify-between items-center">
    <h2 class="text-xl font-bold text-white">Your Saved Tips</h2>
    
    <%= form_with url: saved_tips_path, method: :get, class: "flex items-center space-x-2", data: { form_submission_target: "form" } do |f| %>
      <%= f.label :sort_by, "Sort by:", class: "text-sm font-medium text-dark-text-muted" %>
      <%= f.select :sort_by, 
                   options_for_select(sort_options, @sort_by), 
                   {}, 
                   { 
                     class: "p-2 border rounded-md text-white bg-dark-surface border-dark-border focus:ring-2 focus:ring-accent-500 focus:border-accent-500",
                     data: { action: "change->form-submission#submit" } 
                   } %>
      <%= f.label :tag, "Tag:", class: "text-sm font-medium text-dark-text-muted" %>
      <%= f.select :tag,
                   options_for_select([["All tags", ""]] + Array(@available_tags).map { |tag| [tag.tr("_", " "), tag] }, @tag_filter),
                   {},
                   {
                     class: "p-2 border rounded-md text-white bg-dark-surface border-dark-border focus:ring-2 focus:ring-accent-500 focus:border-accent-500",
                     data: { action: "change->form-submission#submit" }
                   } %>
      <%#= f.submit "Sort", class: "hidden" %>
    <% end %>
  </div>
</div>
