<div id="saved-tip-<%= tip.id %>" class="bg-dark-card rounded-2xl p-6 border border-dark-border">
  <div class="flex items-center justify-between mb-3">
    <div class="flex flex-wrap gap-2 items-center">
      <span class="px-3 py-1 bg-dark-surface rounded-full text-caption">
        <%= tip_category_label(tip) %>
      </span>
      <% if tip.type == "Insight" %>
        <span class="px-3 py-1 bg-dark-surface rounded-full text-caption">
          <%= tip_source_label(tip) %>
        </span>
      <% else %>
        <span class="px-3 py-1 bg-dark-surface rounded-full text-caption">
          <%= tip_phase_label(tip) %>
        </span>
      <% end %>
      <% if tip.hole_number.present? %>
        <span class="px-3 py-1 bg-dark-surface rounded-full text-caption">
          Hole <%= tip.hole_number %>
        </span>
      <% end %>
      <% tip.human_tags.each do |tag| %>
        <span class="px-3 py-1 bg-dark-surface rounded-full text-caption">
          <%= tag %>
        </span>
      <% end %>
    </div>
    <span class="text-caption">
      <%= tip_phase_icon_for(tip) %> <%= tip_phase_label(tip) %>
    </span>
  </div>

  <h3 class="text-heading mb-2"><%= tip.title %></h3>
  <p class="text-body mb-4"><%= truncate(tip.content, length: 150) %></p>

  <% if tip.has_youtube_video? %>
    <div class="mb-4">
      <a href="<%= tip.youtube_url %>" target="_blank" rel="noopener noreferrer" class="block group">
        <div class="relative rounded-lg overflow-hidden bg-dark-surface">
          <img src="<%= tip.youtube_thumbnail_url %>"
               alt="YouTube video thumbnail"
               class="w-full h-24 object-cover group-hover:scale-105 transition-transform duration-200"
               onerror="this.style.display='none'">
          <div class="absolute inset-0 bg-black/30 flex items-center justify-center group-hover:bg-black/40 transition-colors">
            <div class="bg-red-600 rounded-full p-2 group-hover:scale-110 transition-transform">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <div class="absolute bottom-1 right-1 bg-black/70 text-white text-xs px-1 py-0.5 rounded text-xs">
            Watch
          </div>
        </div>
      </a>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <div class="flex items-center space-x-3 text-caption">
      <span>By <%= tip.user.display_name %></span>
      <span>•</span>
      <span><%= time_ago_in_words(tip.created_at) %> ago</span>
    </div>

    <button class="text-red-400 hover:text-red-300 transition-colors text-sm"
            data-turbo-method="delete"
            data-turbo-action="replace"
            data-href="<%= unsave_tip_path(tip) %>">
      Remove
    </button>
  </div>
</div>
