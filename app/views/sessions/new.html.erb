<div class="min-h-screen bg-dark-bg flex flex-col relative">
  <div class="flex-1 flex flex-col items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <!-- Logo -->
      <h1 class="text-5xl font-light text-dark-text text-center mb-16">Golf</h1>

      <!-- Title -->
      <h2 class="text-3xl text-dark-text text-center mb-3">Welcome back</h2>
      <p class="text-dark-text-muted text-center mb-10">Sign in to continue your journey</p>

      <!-- Google Sign In -->
      <div class="mb-6">
        <%= link_to "/auth/google_oauth2",
                      data: { turbo: false },
                      class: "w-full flex justify-center items-center gap-3 bg-white text-gray-900 rounded-full py-3 font-medium text-base hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        <% end %>
      </div>

      <!-- Divider -->
      <div class="relative my-8">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-dark-border"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-4 bg-dark-bg text-dark-text-muted">or</span>
        </div>
      </div>

      <%= form_with url: session_path, local: true, class: "space-y-4" do |f| %>
        <div>
          <%= f.email_field :email_address,
              required: true,
              autofocus: true,
              placeholder: "Email address",
              class: "w-full bg-transparent border border-dark-border rounded-full px-6 py-4 text-dark-text placeholder-dark-text-muted focus:outline-none focus:border-accent-500 text-lg" %>
        </div>

        <div>
          <%= f.password_field :password,
              required: true,
              placeholder: "Password",
              class: "w-full bg-transparent border border-dark-border rounded-full px-6 py-4 text-dark-text placeholder-dark-text-muted focus:outline-none focus:border-accent-500 text-lg" %>
        </div>

        <div class="flex items-center justify-between px-2 pt-1">
          <label class="flex items-center cursor-pointer">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-dark-border bg-transparent text-accent-500 focus:ring-accent-500 focus:ring-offset-0" %>
            <span class="ml-2 text-dark-text-muted text-sm">Remember me</span>
          </label>

          <%= link_to "Forgot password?", new_password_path,
              class: "text-sm text-accent-500 hover:text-accent-400 transition-colors" %>
        </div>

        <%= f.submit "Sign In",
            class: "w-full bg-accent-500 text-white rounded-full py-4 font-medium text-lg cursor-pointer hover:bg-accent-600 transition-colors" %>
      <% end %>

      <!-- Create account -->
      <p class="text-center text-dark-text-muted mt-12">
        Don't have an account?
        <%= link_to "Sign up", new_user_path,
            class: "text-accent-500 hover:text-accent-400 transition-colors font-medium" %>
      </p>
    </div>
  </div>
</div>
