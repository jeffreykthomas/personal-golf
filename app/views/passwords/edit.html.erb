<div class="min-h-screen bg-dark-bg flex flex-col relative">
  <div class="flex-1 flex flex-col items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <h2 class="text-3xl text-dark-text text-center mb-3">Update your password</h2>
      <p class="text-dark-text-muted text-center mb-10">Choose a new password for your account</p>

      <% if alert = flash[:alert] %>
        <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-4 mb-6">
          <p class="text-sm text-red-400"><%= alert %></p>
        </div>
      <% end %>

      <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4" do |form| %>
        <div>
          <%= form.password_field :password,
              required: true,
              autocomplete: "new-password",
              placeholder: "New password",
              maxlength: 72,
              class: "w-full bg-transparent border border-dark-border rounded-full px-6 py-4 text-dark-text placeholder-dark-text-muted focus:outline-none focus:border-accent-500 text-lg" %>
        </div>

        <div>
          <%= form.password_field :password_confirmation,
              required: true,
              autocomplete: "new-password",
              placeholder: "Confirm new password",
              maxlength: 72,
              class: "w-full bg-transparent border border-dark-border rounded-full px-6 py-4 text-dark-text placeholder-dark-text-muted focus:outline-none focus:border-accent-500 text-lg" %>
        </div>

        <%= form.submit "Save Password",
            class: "w-full bg-accent-500 text-white rounded-full py-4 font-medium text-lg cursor-pointer hover:bg-accent-600 transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
