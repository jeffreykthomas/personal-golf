<li class="space-y-2">
  <%= link_to learning_path(node_id: node.id), class: "block rounded-2xl border px-3 py-3 transition-colors #{selected_node_id == node.id ? 'border-accent-500 bg-accent-500/10' : 'border-dark-border bg-dark-surface/60 hover:border-accent-400'}" do %>
    <div class="flex items-center justify-between gap-3">
      <span class="text-sm font-medium text-white"><%= node.title %></span>
      <% if node.children.any? %>
        <span class="rounded-full bg-dark-bg/80 px-2 py-0.5 text-[10px] font-medium text-dark-text-muted"><%= node.children.count %></span>
      <% end %>
    </div>
    <% if node.summary.present? %>
      <p class="text-xs leading-5 text-dark-text-muted mt-1"><%= truncate(node.summary, length: 110) %></p>
    <% end %>
  <% end %>

  <% if node.children.any? %>
    <ul class="ml-4 border-l border-dark-border pl-3 space-y-2">
      <% node.ordered_children.each do |child| %>
        <%= render "learning/tree_item", node: child, selected_node_id: selected_node_id %>
      <% end %>
    </ul>
  <% end %>
</li>
