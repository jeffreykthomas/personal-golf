<div class="min-h-screen bg-dark-bg flex flex-col relative">
  <div class="flex-1 flex flex-col items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
      <!-- Back link -->
      <div class="mb-12">
        <%= link_to new_session_path, class: "inline-flex items-center text-dark-text-muted hover:text-white transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to sign in
        <% end %>
      </div>

      <h2 class="text-3xl text-dark-text text-center mb-3">Forgot your password?</h2>
      <p class="text-dark-text-muted text-center mb-10">Enter your email and we'll send you reset instructions</p>

      <% if alert = flash[:alert] %>
        <div class="bg-red-500/10 border border-red-500/20 rounded-2xl p-4 mb-6">
          <p class="text-sm text-red-400"><%= alert %></p>
        </div>
      <% end %>

      <%= form_with url: passwords_path, class: "space-y-4" do |form| %>
        <div>
          <%= form.email_field :email_address,
              required: true,
              autofocus: true,
              autocomplete: "username",
              placeholder: "Email address",
              value: params[:email_address],
              class: "w-full bg-transparent border border-dark-border rounded-full px-6 py-4 text-dark-text placeholder-dark-text-muted focus:outline-none focus:border-accent-500 text-lg" %>
        </div>

        <%= form.submit "Send Reset Instructions",
            class: "w-full bg-accent-500 text-white rounded-full py-4 font-medium text-lg cursor-pointer hover:bg-accent-600 transition-colors" %>
      <% end %>
    </div>
  </div>
</div>
